      {
        "id": "454fbd7b-de1d-4485-a637-f25f734d326b",
        "name": "Code in JavaScript",
        "parameters": {
          "jsCode": "const out = [];\nfor (const item of $input.all()) {\n  const json = item.json; // теперь json — это объект вида { room_id, body, url, ... }\n  const mxcUrl = json.url; // url находится на верхнем уровне\n\n  if (!mxcUrl || !mxcUrl.startsWith('mxc://')) {\n    out.push({ json });\n    continue;\n  }\n\n  const match = mxcUrl.match(/^mxc:\\/\\/([^\\/]+)\\/(.+)$/);\n  if (!match) {\n    out.push({ json });\n    continue;\n  }\n\n  const [_, server, mediaId] = match;\n  const downloadUrl = `https://matrix.itcomp.org/_matrix/client/v1/media/download/${server}/${mediaId}?allow_remote=true`;\n\n  out.push({\n    json: {\n      ...json,\n      downloadUrl\n    }\n  });\n}\nreturn out;"
        },
