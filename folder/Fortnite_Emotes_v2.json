    {
      "id": "9c421b50-b8a5-4e23-b8f0-d9386faae3d7",
      "name": "Filter Image",
      "parameters": {
        "jsCode": "const items = $('Parse Bria').all();\nconst meta = items[$itemIndex]?.json || {};\nconst bin = $input.item.binary;\nif (!bin || !Object.keys(bin).length) return { json: { ...meta, _skip: true } };\nconst k = Object.keys(bin)[0];\nreturn { json: meta, binary: { image: { ...bin[k], fileName: meta.img_file, mimeType: 'image/png' } } };",
        "mode": "runOnceForEachItem"
