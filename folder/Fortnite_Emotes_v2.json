    {
      "id": "f230c27e-c88b-4e2f-a29a-dfcab3e029ea",
      "name": "Fetch API",
      "parameters": {
        "options": {
          "timeout": 120000
        },
        "url": "https://fortnite-api.com/v2/cosmetics/br"
      },
