      "name": "Parse Bria",
      "parameters": {
        "jsCode": "const items = $('Process Emotes').all();\nconst meta = items[$itemIndex]?.json || {};\nconst r = $json;\nconst url = r.result?.image_url || r.image_url || meta.image_url;\nreturn { json: { ...meta, processed_url: url } };",
