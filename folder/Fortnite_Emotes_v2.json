    {
      "id": "ba0bb9c2-2545-4571-b28a-1c60b3ad9aab",
      "name": "Merge Video",
      "parameters": {
        "jsCode": "const imgItems = $('Has Image?').all().filter(i => !i.json._skip);\nconst meta = imgItems[$itemIndex]?.json || {};\nconst prevBin = imgItems[$itemIndex]?.binary || {};\nconst vidBin = $input.item.binary || {};\n\nconst newBin = { ...prevBin };\nif (vidBin && Object.keys(vidBin).length) {\n  const k = Object.keys(vidBin)[0];\n  newBin.video = { ...vidBin[k], fileName: meta.vid_file, mimeType: 'video/mp4' };\n}\n\nreturn { json: { ...meta, has_video: !!newBin.video }, binary: newBin };",
        "mode": "runOnceForEachItem"
      },
