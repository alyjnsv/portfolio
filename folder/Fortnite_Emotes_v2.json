      "typeVersion": 2
    },
    {
      "id": "916ba35e-5717-4fd5-aad1-f3d8056b9c87",
      "name": "Aggregate",
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "items",
        "options": {}
      },
