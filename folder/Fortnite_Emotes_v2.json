        "jsCode": "const input = $json;\nreturn [{ json: {\n  chat_id: input.chat_id,\n  count: input.config?.emotes?.count || 60,\n  min_per_rarity: input.config?.emotes?.min_per_rarity || 10,\n  id_start: input.id_ranges?.emotes?.start || 200000,\n  bria_token: input.bria_token || '130a9262fe6349b9bc9fd2dfbd2fd2d8'\n}}];"
