    {
      "id": "1e3816ec-5d58-4d26-90ae-730257783896",
      "name": "Restore Video",
      "parameters": {
        "jsCode": "const mergeItems = $('Merge Video').all();\nconst meta = mergeItems[$itemIndex]?.json || {};\nconst origBin = mergeItems[$itemIndex]?.binary || {};\nconst resizedBin = $input.item.binary || {};\n\nconst newBin = {};\nif (resizedBin.image) newBin.image = { ...resizedBin.image, fileName: meta.img_file, mimeType: 'image/png' };\nif (origBin.video) newBin.video = origBin.video;\n\nreturn { json: meta, binary: newBin };",
        "mode": "runOnceForEachItem"
      },
      "position": [
        1024,
        1040
      ],
