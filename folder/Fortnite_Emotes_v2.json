    {
      "id": "0fdcf0dd-33c7-43f1-8a53-ed73c2f75893",
      "name": "Process Emotes",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (['common','uncommon','rare','epic','legendary'].includes(v)) return v;\n  return 'other';\n};\n\nconst emotes = cosmetics.filter(i => i.type?.value === 'emote' && (i.images?.icon || i.images?.smallIcon));\n\nconst byRarity = {};\nfor (const r of RARITIES) byRarity[r] = [];\nfor (const e of emotes) byRarity[normalize(e.rarity)].push(e);\n\nconst selected = [];\nconst used = new Set();\n\n// First: 10 per rarity\nfor (const r of RARITIES) {\n  const pool = byRarity[r].sort(() => Math.random() - 0.5);\n  let c = 0;\n  for (const e of pool) {\n    if (c >= config.min_per_rarity) break;\n    if (used.has(e.id)) continue;\n    selected.push({ ...e, _rarity: r });\n    used.add(e.id);\n    c++;\n  }\n}\n\n// Fill remaining\nconst remaining = emotes.filter(e => !used.has(e.id)).sort(() => Math.random() - 0.5);\nfor (const e of remaining) {\n  if (selected.length >= config.count) break;\n  selected.push({ ...e, _rarity: normalize(e.rarity) });\n}\n\nreturn selected.map((e, i) => {\n  const numId = e.id.replace(/\\D/g, '') || i;\n  return {\n    json: {\n      id: config.id_start + i,\n      api_id: e.id,\n      name: e.name || '',\n      rarity: e._rarity,\n      image_url: e.images?.icon || e.images?.smallIcon,\n      vid_url: `https://fnggcdn.com/items/${numId}/video.mp4`,\n      img_file: `${config.id_start + i}.png`,\n      vid_file: `${config.id_start + i}.mp4`,\n      _chat_id: config.chat_id,\n      _bria: config.bria_token\n    }\n  };\n});"
      },
      "position": [
        -784,
        1136
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
