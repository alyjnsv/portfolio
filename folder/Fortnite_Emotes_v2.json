    {
      "id": "3471b694-591a-4cb5-8b1d-c07853e3a17a",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Restore Video').all();\nlet chatId = items[0]?._chat_id || 0;\n\n// CSV: id, name, image, rarity, video\nconst csv = ['id,name,image,rarity,video'];\nfor (const item of items) {\n  if (!item._skip) {\n    csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.img_file},${item.rarity},${item.vid_file}`);\n  }\n}\n\n// Collect binaries (both PNG and MP4)\nconst binData = {};\nconst keys = [];\nlet imgCount = 0, vidCount = 0;\n\nfor (const f of finalItems) {\n  if (f.binary?.image) { binData[f.json.img_file] = f.binary.image; keys.push(f.json.img_file); imgCount++; }\n  if (f.binary?.video) { binData[f.json.vid_file] = f.binary.video; keys.push(f.json.vid_file); vidCount++; }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: imgCount, videos: vidCount }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'emotes.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: imgCount, videos: vidCount, keys: keys.join(',') }, binary: binData }\n];"
      },
