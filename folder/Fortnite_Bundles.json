      "parameters": {
        "jsCode": "const items=$('Parse Bria').all(); const meta=items[$itemIndex]?.json||{}; const bin=$input.item.binary;\nif(!bin||!Object.keys(bin).length)return{json:{...meta,_skip:true}};\nconst k=Object.keys(bin)[0]; return{json:meta,binary:{image:{...bin[k],fileName:meta.img_file,mimeType:'image/png'}}};",
