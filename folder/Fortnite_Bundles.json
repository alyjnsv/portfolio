    {
      "id": "3b28e4ad-3129-40d3-848d-fa3a87a1fece",
      "name": "Process Bundles",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\n\nconst skins = cosmetics.filter(i => i.type?.value === 'outfit' && i.images?.icon).sort(() => Math.random() - 0.5);\nconst emotes = cosmetics.filter(i => i.type?.value === 'emote' && i.images?.icon).sort(() => Math.random() - 0.5);\nconst items = cosmetics.filter(i => ['glider','backpack','contrail'].includes(i.type?.value) && i.images?.icon).sort(() => Math.random() - 0.5);\nconst weapons = cosmetics.filter(i => ['pickaxe','wrap'].includes(i.type?.value) && i.images?.icon).sort(() => Math.random() - 0.5);\n\nconst bundles = [];\nconst used = { s: new Set(), e: new Set(), i: new Set(), w: new Set() };\n\nfor (let b = 0; b < config.count; b++) {\n  const skin = skins.find(x => !used.s.has(x.id));\n  const emote = emotes.find(x => !used.e.has(x.id));\n  const item = items.find(x => !used.i.has(x.id));\n  const weapon = weapons.find(x => !used.w.has(x.id));\n  \n  if (!skin || !emote || !item || !weapon) break;\n  \n  used.s.add(skin.id); used.e.add(emote.id); used.i.add(item.id); used.w.add(weapon.id);\n  \n  bundles.push({\n    id: `bundle_${b}`,\n    name: `${skin.name} Bundle`,\n    rarity: (skin.rarity?.value || 'rare').toLowerCase(),\n    image_url: skin.images.icon,\n    img_file: `bundle_${b}.png`,\n    elements: [\n      { type: 'skin', id: skin.id },\n      { type: 'emote', id: emote.id },\n      { type: 'item', id: item.id },\n      { type: 'weapon', id: weapon.id }\n    ],\n    _chat_id: config.chat_id,\n    _bria: config.bria_token\n  });\n}\n\nreturn bundles.map(b => ({ json: b }));"
      },
      "position": [
        -1728,
        1104
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
