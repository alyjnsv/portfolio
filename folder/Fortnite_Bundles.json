    {
      "id": "1a43f947-3eac-4b9e-abb9-89c717532fa3",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items=$json.items||[]; const finalItems=$('Finalize').all(); let chatId=items[0]?._chat_id||0;\nconst csv=['id,name,rarity,image,skin_id,emote_id,item_id,weapon_id'];\nfor(const i of items){\n  const el=i.elements||[];\n  csv.push(`${i.id},\"${(i.name||'').replace(/\"/g,'')}\",${i.rarity},${i.img_file},${el.find(x=>x.type==='skin')?.id||''},${el.find(x=>x.type==='emote')?.id||''},${el.find(x=>x.type==='item')?.id||''},${el.find(x=>x.type==='weapon')?.id||''}`);\n}\nconst binData={},keys=[]; for(const f of finalItems){if(f.binary?.image){binData[f.json.img_file]=f.binary.image;keys.push(f.json.img_file);}}\nreturn[\n  {json:{type:'csv',chat_id:chatId,count:items.length},binary:{file:{data:Buffer.from(csv.join('\\n')).toString('base64'),mimeType:'text/csv',fileName:'bundles.csv'}}},\n  {json:{type:'zip',chat_id:chatId,count:items.length,keys:keys.join(',')},binary:binData}\n];"
      },
