      "id": "ff50c406-02a0-41f1-8aa4-26cda7d823a0",
      "name": "Code in JavaScript",
      "parameters": {
        "jsCode": "const workflow = $input.first().json;\n\n// Находим всех агентов\nconst agentNodes = workflow.nodes.filter(\n  node => node.type === '@n8n/n8n-nodes-langchain.agent'\n);\n\nif (agentNodes.length === 0) {\n  return []; // Нет агентов — выходим\n}\n\n// Обновляем каждого агента\nfor (const agent of agentNodes) {\n  // 1. Обновляем параметры агента\n  agent.parameters.promptType = 'define';\n  agent.parameters.text = '={{ $json.chatInput }}';\n  agent.parameters.options = agent.parameters.options || {};\n  agent.parameters.options.systemMessage = \n    '=Обратись к data table для получения промпта, полученный промпт используй для обработки входящего сообщения, обработай полученное сообщение сразу же, не спрашивай, не добавляй доп. текст, просто исполни инструкцию которую ты получил из data table';\n\n  // 2. Генерируем ID инструмента для этого агента\n  const toolId = `datatable-tool-for-${agent.id}`;\n  \n  // 3. Ищем существующий инструмент\n  let toolNode = workflow.nodes.find(n => n.id === toolId);\n  \n  if (!toolNode) {\n    // Создаём новый инструмент\n    toolNode = {\n      parameters: {\n        operation: \"get\",\n        dataTableId: {\n          \"__rl\": true,\n          \"value\": \"VzaWf779bSTwqxiQ\",\n          \"mode\": \"list\"\n        },\n        matchType: \"allConditions\",\n        filters: {\n          conditions: [\n            { keyName: \"node_id\", keyValue: agent.id } // ← уникальный ID!\n          ]\n        },\n        limit: 1000\n      },\n      type: \"n8n-nodes-base.dataTableTool\",\n      typeVersion: 1,\n      position: [agent.position[0] + 160, agent.position[1]],\n      id: toolId,\n      name: `Get prompt for ${agent.name}`\n    };\n    workflow.nodes.push(toolNode);\n  } else {\n    // Обновляем фильтр на случай изменений\n    toolNode.parameters.filters.conditions[0].keyValue = agent.id;\n  }\n\n  // 4. Обновляем connections: подключаем инструмент к этому агенту\n  workflow.connections = workflow.connections || {};\n  if (!workflow.connections[toolNode.name]) {\n    workflow.connections[toolNode.name] = {};\n  }\n  workflow.connections[toolNode.name].ai_tool = [[\n    { node: agent.name, type: \"ai_tool\", index: 0 }\n  ]];\n}\n\n// Возвращаем обновлённый workflow\nreturn { json: workflow };"
      },
