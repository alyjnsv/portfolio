    {
      "id": "035eeefb-3c64-4a42-988b-f5ab845f4467",
      "name": "Finalize",
      "parameters": {
        "jsCode": "const items=$('Has Image?').all().filter(i=>!i.json._skip); const meta=items[$itemIndex]?.json||{}; const bin=$input.item.binary||{};\nconst newBin={}; if(bin.image)newBin.image={...bin.image,fileName:meta.img_file,mimeType:'image/png'};\nreturn{json:meta,binary:newBin};",
        "mode": "runOnceForEachItem"
