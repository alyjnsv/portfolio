    {
      "id": "a1148925-4690-447e-8fcf-a95a71b70abd",
      "name": "Process Items",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\nconst ITEM_TYPES = ['pickaxe', 'glider', 'backpack', 'contrail', 'wrap'];\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => { const v=(r?.value||'other').toLowerCase(); return RARITIES.slice(0,5).includes(v)?v:'other'; };\n\nconst items = cosmetics.filter(i => ITEM_TYPES.includes(i.type?.value) && (i.images?.icon || i.images?.smallIcon));\nconst byRarity = {}; for(const r of RARITIES) byRarity[r]=[];\nfor(const i of items) byRarity[normalize(i.rarity)].push(i);\n\nconst selected = [], used = new Set();\nfor(const r of RARITIES){ let c=0; for(const i of byRarity[r].sort(()=>Math.random()-0.5)){ if(c>=10)break; selected.push(i);used.add(i.id);c++; }}\nfor(const i of items.filter(x=>!used.has(x.id)).sort(()=>Math.random()-0.5)){ if(selected.length>=config.count)break; selected.push(i); }\n\nreturn selected.map((i,idx)=>({\n  json:{ id:i.id, name:i.name||'', rarity:normalize(i.rarity), type:i.type?.value, image_url:i.images?.icon||i.images?.smallIcon, img_file:`${i.id}.png`, _chat_id:config.chat_id, _bria:config.bria_token }\n}));"
      },
      "position": [
        -800,
        1136
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "continueOnFail": true,
      "id": "70578e62-0652-45a8-a3a8-c2a9ab63149e",
      "name": "Bria",
      "parameters": {
        "headerParameters": {
          "parameters": [
            {
              "name": "api_token",
              "value": "130a9262fe6349b9bc9fd2dfbd2fd2d8"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "jsonBody": "={ \"image\": \"{{ $json.image_url }}\", \"sync\": true }",
        "method": "POST",
        "options": {
          "timeout": 60000
        },
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "url": "https://engine.prod.bria-api.com/v2/image/edit/remove_background"
      },
