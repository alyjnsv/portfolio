    {
      "id": "9d5278e0-ec8a-481f-b7a7-cd95e85bf495",
      "name": "Parse Bria",
      "parameters": {
        "jsCode": "const items=$('Process Items').all(); const meta=items[$itemIndex]?.json||{}; const r=$json;\nreturn{json:{...meta,processed_url:r.result?.image_url||r.image_url||meta.image_url}};",
        "mode": "runOnceForEachItem"
      },
      "position": [
        -400,
        1136
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
