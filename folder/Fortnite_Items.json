    {
      "id": "c18b6af9-aa75-4c21-bfd4-1469bf8575e2",
      "name": "Fetch API",
      "parameters": {
        "options": {
          "timeout": 120000
        },
        "url": "https://fortnite-api.com/v2/cosmetics/br"
      },
      "position": [
        -992,
        1136
      ],
      "type": "n8n-nodes-base.httpRequest",
