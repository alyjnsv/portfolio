    {
      "id": "9ebf9669-9b67-431a-8f6b-3b87f9bd4288",
      "name": "Process Weapons",
      "parameters": {
        "jsCode": "// Use Fortnite API instead - get ranged weapons from cosmetics\nconst cosmetics = $json.data || [];\nconst config = $('Config').first().json;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => { const v=(r?.value||'other').toLowerCase(); return RARITIES.slice(0,5).includes(v)?v:'other'; };\n\n// Get items that look like weapons: pickaxe, wrap, etc\nconst weapons = [];\n\n// Option 1: Use pickaxes as \"melee weapons\"\nconst pickaxes = cosmetics.filter(i => i.type?.value === 'pickaxe' && i.images?.icon);\nfor (let i = 0; i < Math.min(pickaxes.length, config.count); i++) {\n  const p = pickaxes[i];\n  weapons.push({\n    id: `weapon_${i}`,\n    name: p.name || `Weapon ${i}`,\n    rarity: normalize(p.rarity),\n    type: 'melee',\n    image_url: p.images.icon,\n    img_file: `weapon_${i}.png`,\n    _chat_id: config.chat_id\n  });\n}\n\n// If not enough, add wraps\nif (weapons.length < config.count) {\n  const wraps = cosmetics.filter(i => i.type?.value === 'wrap' && i.images?.icon);\n  for (let i = 0; weapons.length < config.count && i < wraps.length; i++) {\n    const w = wraps[i];\n    weapons.push({\n      id: `weapon_${weapons.length}`,\n      name: w.name || `Weapon ${weapons.length}`,\n      rarity: normalize(w.rarity),\n      type: 'ranged',\n      image_url: w.images.icon,\n      img_file: `weapon_${weapons.length}.png`,\n      _chat_id: config.chat_id\n    });\n  }\n}\n\n// Shuffle and select by rarity\nconst shuffled = weapons.sort(() => Math.random() - 0.5);\nconst byRarity = {}; for(const r of RARITIES) byRarity[r]=[];\nfor(const w of shuffled) byRarity[w.rarity].push(w);\n\nconst selected = [], used = new Set();\nfor(const r of RARITIES){ let c=0; for(const w of byRarity[r]){ if(c>=10||used.has(w.id))continue; selected.push(w);used.add(w.id);c++; }}\nfor(const w of shuffled){ if(selected.length>=config.count)break; if(!used.has(w.id)){selected.push(w);used.add(w.id);} }\n\nreturn selected.map(w => ({ json: w }));"
      },
