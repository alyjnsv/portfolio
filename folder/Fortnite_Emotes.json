      "id": "3871669c-8f8d-4f86-b5dd-aaa290876825",
      "name": "Parse Video",
      "parameters": {
        "jsCode": "const items = $('Process Emotes1').all();\nconst meta = items[$itemIndex]?.json || {};\nconst bin = $input.item.binary || {};\n\nif (!bin || !Object.keys(bin).length) {\n  return { json: { ...meta, _skip: true } };\n}\n\nconst k = Object.keys(bin)[0];\nreturn {\n  json: { ...meta, has_video: true },\n  binary: { video: { ...bin[k], fileName: meta.vid_file, mimeType: 'video/mp4' } }\n};",
        "mode": "runOnceForEachItem"
