    {
      "id": "510f6eec-fdff-4a46-a2f5-7a55f7598701",
      "name": "Process Emotes1",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config1').first().json;\nconst chatId = config.chat_id;\nconst count = config.count;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (RARITIES.slice(0,5).includes(v)) return v;\n  return 'other';\n};\n\nconst emotes = cosmetics.filter(i => i.type?.value === 'emote');\n\nconst byRarity = {};\nfor (const r of RARITIES) byRarity[r] = [];\nfor (const e of emotes) byRarity[normalize(e.rarity)].push(e);\n\nconst selected = [];\nconst used = new Set();\n\nfor (const r of RARITIES) {\n  const pool = byRarity[r].sort(() => Math.random() - 0.5);\n  let c = 0;\n  for (const e of pool) {\n    if (c >= 10) break;\n    selected.push(e); used.add(e.id); c++;\n  }\n}\n\nconst remaining = emotes.filter(e => !used.has(e.id)).sort(() => Math.random() - 0.5);\nfor (const e of remaining) {\n  if (selected.length >= count) break;\n  selected.push(e);\n}\n\nreturn selected.map((e, i) => {\n  const numId = e.id.replace(/\\D/g, '') || i;\n  return {\n    json: {\n      id: e.id,\n      name: e.name || '',\n      rarity: normalize(e.rarity),\n      vid_file: `${e.id}.mp4`,\n      vid_url: `https://fnggcdn.com/items/${numId}/video.mp4`,\n      _idx: i,\n      _chat_id: chatId\n    }\n  };\n});"
      },
      "position": [
        -736,
        1136
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
