    {
      "id": "8826e97c-a89e-4e9e-848c-927aebb49ccf",
      "name": "Build Output1",
      "parameters": {
        "jsCode": "// В Build Output замени код на:\nconst items = $json.items || [];\nconst videoItems = $('Has Video?').all().filter(i => !i.json._skip);\nlet chatId = items[0]?._chat_id || 0;\n\n// Build CSV\nconst csv = ['id,name,rarity,video'];\nfor (const item of items) {\n  if (!item._skip) {\n    csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.rarity},${item.vid_file}`);\n  }\n}\n\n// Split into chunks of 25 videos\nconst CHUNK_SIZE = 25;\nconst outputs = [];\n\n// First: CSV file\noutputs.push({ \n  json: { type: 'csv', chat_id: chatId, count: videoItems.length }, \n  binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'emotes.csv' } } \n});\n\n// Then: Multiple ZIPs\nlet chunkIndex = 1;\nfor (let i = 0; i < videoItems.length; i += CHUNK_SIZE) {\n  const chunk = videoItems.slice(i, i + CHUNK_SIZE);\n  const binData = {};\n  const keys = [];\n  \n  for (const f of chunk) {\n    if (f.binary?.video) {\n      binData[f.json.vid_file] = f.binary.video;\n      keys.push(f.json.vid_file);\n    }\n  }\n  \n  if (keys.length > 0) {\n    outputs.push({ \n      json: { type: 'zip', chat_id: chatId, count: keys.length, part: chunkIndex, keys: keys.join(',') }, \n      binary: binData \n    });\n    chunkIndex++;\n  }\n}\n\nreturn outputs;"
      },
