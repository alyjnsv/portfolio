    {
      "id": "de4c3db0-c1e2-440b-a995-9a4602636c4f",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Finalize').all();\nlet chatId = items[0]?._chat_id || 0;\n\n// Build CSV\nconst csv = ['id,name,rarity,image'];\nfor (const item of items) {\n  csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.rarity},${item.img_file}`);\n}\n\n// Collect binaries\nconst binData = {};\nconst keys = [];\n\nfor (const f of finalItems) {\n  if (f.binary?.image) {\n    const fn = f.json.img_file;\n    binData[fn] = f.binary.image;\n    keys.push(fn);\n  }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: items.length }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'skins.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: items.length, keys: keys.join(',') }, binary: binData }\n];"
      },
