    {
      "id": "bda257be-80d6-46ec-9aa2-112766ae3cbf",
      "name": "Process Skins",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\nconst chatId = config.chat_id;\nconst count = config.count;\nconst briaToken = config.bria_token;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (RARITIES.slice(0,5).includes(v)) return v;\n  return 'other';\n};\n\n// Filter outfits only\nconst skins = cosmetics.filter(i => i.type?.value === 'outfit' && (i.images?.icon || i.images?.featured));\n\n// Group by rarity\nconst byRarity = {};\nfor (const r of RARITIES) byRarity[r] = [];\nfor (const s of skins) {\n  const r = normalize(s.rarity);\n  byRarity[r].push(s);\n}\n\n// Select: 10 per rarity, then fill to count\nconst selected = [];\nconst used = new Set();\n\nfor (const r of RARITIES) {\n  const pool = byRarity[r].sort(() => Math.random() - 0.5);\n  let c = 0;\n  for (const s of pool) {\n    if (c >= 10) break;\n    selected.push(s);\n    used.add(s.id);\n    c++;\n  }\n}\n\nconst remaining = skins.filter(s => !used.has(s.id)).sort(() => Math.random() - 0.5);\nfor (const s of remaining) {\n  if (selected.length >= count) break;\n  selected.push(s);\n}\n\n// Output items\nreturn selected.map((s, i) => ({\n  json: {\n    id: s.id,\n    name: s.name || '',\n    rarity: normalize(s.rarity),\n    image_url: s.images?.icon || s.images?.featured,\n    img_file: `${s.id}.png`,\n    _idx: i,\n    _chat_id: chatId,\n    _bria: briaToken\n  }\n}));"
      },
      "position": [
        -1712,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
