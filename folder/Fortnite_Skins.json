    {
      "id": "a44ad99e-eec4-4002-8547-949bada661d1",
      "name": "Fetch API",
      "parameters": {
        "options": {
          "timeout": 120000
        },
        "url": "https://fortnite-api.com/v2/cosmetics/br"
      },
