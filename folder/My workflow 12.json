    {
      "id": "d06f69ca-5dcc-4ec9-9857-294009e1814b",
      "name": "Parse Tasks",
      "parameters": {
        "jsCode": "// Парсим результат извлечения задач\nlet tasksData;\ntry {\n  const rawText = $node[\"Extract Tasks\"].json.content.parts[0].text;\n  const jsonText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n  tasksData = JSON.parse(jsonText);\n} catch (e) {\n  tasksData = { has_tasks: false, tasks: [] };\n}\n\nreturn tasksData;"
      },
