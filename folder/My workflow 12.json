    {
      "id": "1d343f78-7803-4888-8506-14f14df852fb",
      "name": "Combine Data1",
      "parameters": {
        "jsCode": "// Получаем данные из всех источников\nconst summary = $node[\"Meeting Summary\"].json.content.parts[0].text || \"Резюме недоступно\";\nconst tasksData = $node[\"Parse Tasks\"].json || {};\nconst hasTasks = tasksData.hasTasks || false;\n\nlet jiraLinks = [];\nlet tasksSection = \"\";\n\nif (hasTasks) {\n  try {\n    const jiraItems = $node[\"Create Jira Task2\"].all();\n    jiraLinks = jiraItems.map(item => {\n      return `- [${item.json.key}](https://ii.jira/browse/${item.json.key}): ${item.json.fields.summary}`;\n    });\n    \n    tasksSection = `\\n\\n## 📋 Созданные задачи в Jira\\n${jiraLinks.join('\\n')}`;\n  } catch (e) {\n    // Если задачи есть, но Jira не сработала\n    const tasks = tasksData.tasks || [];\n    const tasksList = tasks.map(t => `- **${t.title}** (${t.assignee}, до ${t.deadline})`);\n    tasksSection = `\\n\\n## 📋 Выявленные задачи\\n${tasksList.join('\\n')}\\n\\n⚠️ *Задачи не были созданы в Jira*`;\n  }\n} else {\n  tasksSection = \"\\n\\n## 📋 Задачи\\nНа встрече не было выявлено конкретных задач.\";\n}\n\n// Формируем итоговый отчет\nconst report = `# 📊 Протокол встречи\\n\\n${summary}${tasksSection}\\n\\n---\\n✅ *Отчет сформирован автоматически*`;\n\nreturn {\n  report: report,\n  chatId: $node[\"Telegram Trigger3\"].json.message.chat.id\n};"
      },
