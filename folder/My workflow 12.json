      "id": "7e87d135-cb2c-4503-8e9b-2c33d038e95e",
      "name": "Split Tasks",
      "parameters": {
        "jsCode": "// Разделяем задачи для обработки по одной\nconst tasks = $json.tasks || [];\nreturn tasks.map(task => ({ json: task }));"
      },
      "position": [
        16512,
        13728
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "6872523d-61c0-4188-adda-9a9f23124d15",
      "name": "Merge Data1",
      "parameters": {
        "jsCode": "// Собираем все данные для финального отчета\nlet summary = '';\nlet tasks = [];\nlet jiraLinks = [];\n\n// Получаем резюме встречи\ntry {\n  summary = $node[\"Meeting Summary\"].json.content.parts[0].text;\n} catch (e) {\n  summary = 'Резюме встречи недоступно';\n}\n\n// Получаем список задач\ntry {\n  const tasksData = $node[\"Parse Tasks\"].json;\n  if (tasksData.has_tasks && tasksData.tasks) {\n    tasks = tasksData.tasks;\n  }\n} catch (e) {\n  tasks = [];\n}\n\n// Получаем ссылки на Jira (если задачи были созданы)\ntry {\n  const jiraItems = $node[\"Create Jira Task\"].all();\n  jiraItems.forEach(item => {\n    if (item.json.key) {\n      jiraLinks.push({\n        key: item.json.key,\n        url: `https://jira.jira/browse/${item.json.key}`\n      });\n    }\n  });\n} catch (e) {\n  // Задачи в Jira не создавались\n}\n\nreturn {\n  summary: summary,\n  tasks: tasks,\n  jiraLinks: jiraLinks\n};"
      },
      "position": [
        16800,
        13936
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "a49f02cf-e4af-4d6c-98c1-e419e25d55c7",
      "name": "Format Report1",
      "parameters": {
        "jsCode": "// Формируем финальный протокол встречи\nconst data = $json;\n\nlet report = '📋 **ПРОТОКОЛ ВСТРЕЧИ**\\n\\n';\nreport += '---\\n\\n';\n\n// Добавляем резюме\nreport += '📝 **РЕЗЮМЕ ВСТРЕЧИ:**\\n';\nreport += data.summary + '\\n\\n';\nreport += '---\\n\\n';\n\n// Добавляем задачи\nif (data.tasks && data.tasks.length > 0) {\n  report += '✅ **ЗАДАЧИ:**\\n\\n';\n  data.tasks.forEach((task, index) => {\n    report += `${index + 1}. **${task.title}**\\n`;\n    report += `   📌 Описание: ${task.description}\\n`;\n    report += `   👤 Ответственный: ${task.assignee}\\n`;\n    report += `   📅 Срок: ${task.due_date}\\n`;\n    report += `   ⚡ Приоритет: ${task.priority}\\n`;\n    \n    // Добавляем ссылку на Jira, если есть\n    if (data.jiraLinks && data.jiraLinks[index]) {\n      report += `   🔗 Jira: ${data.jiraLinks[index].url}\\n`;\n    }\n    report += '\\n';\n  });\n} else {\n  report += '✅ **ЗАДАЧИ:** Задачи не выявлены\\n\\n';\n}\n\nreport += '---\\n\\n';\nreport += '✨ Протокол сформирован автоматически системой VideoToTask Helper Bot';\n\nreturn { report: report };"
      },
      "position": [
        17008,
        13936
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    }
