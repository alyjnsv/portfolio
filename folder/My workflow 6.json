      "parameters": {
        "jsCode": "// Вход: текст из Telegram, например, \"Идея1\\nИдея2\\nИдея3\" или \"1. Идея1 2. Идея2\"\nconst text = $('Edit Fields').first().json.text// Получаем текст сообщения\n\n// Разделяем по новым строкам (или адаптируй: по ',' или регуляркой для номеров)\nlet ideas = text.split('\\n').map(idea => idea.trim()).filter(idea => idea.length > 0);\n\n// Если идеи нумерованы (типа \"1. ...\"), используй regex для очистки\n// ideas = text.split(/\\d+\\./).map(idea => idea.trim()).filter(idea => idea.length > 0);\nideas = ideas.map(idea => idea.replace(/^\\d+\\.\\s*/, ''));\n\n// Возвращаем массив объектов, где каждый — отдельная идея\nreturn ideas.map(idea => ({ json: { idea } }));"
