      "id": "8cc5c0a1-a5a2-4253-9625-1c2ce8b84d91",
      "name": "Code",
      "parameters": {
        "jsCode": "const items = $input.first().json.text;\n\nlet result = '';\nfor (const item of items) {\n  if (item.json?.data?.text) {\n    result = item.json.data.text;\n    break;\n  }\n}\n\n// Удаляем все \\r, \\n, \\t, заменяя на пробел\nlet cleanedText = result.replace(/[\\r\\n\\t]+/g, ' ');\n\n// Заменяем маркеры \"•\" и точки с пробелом на дефис и пробел\ncleanedText = cleanedText.replace(/•/g, '-');\n\n// Убираем лишние пробелы (больше одного подряд)\ncleanedText = cleanedText.replace(/ +/g, ' ').trim();\n\nreturn [\n  {\n    json: {\n      result: cleanedText\n    }\n  }\n];\n"
