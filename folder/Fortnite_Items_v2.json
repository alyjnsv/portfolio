    {
      "id": "45d16014-84bd-4085-90a3-20719758811b",
      "name": "Fetch API",
      "parameters": {
        "options": {
          "timeout": 120000
        },
        "url": "https://fortnite-api.com/v2/cosmetics/br"
      },
      "position": [
        -992,
        1136
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2
    },
    {
      "id": "db29118f-795d-4159-baba-8d294275d15f",
      "name": "Process Items",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (['common','uncommon','rare','epic','legendary'].includes(v)) return v;\n  return 'other';\n};\n\n// Type mapping from API to ТЗ\nconst TYPE_MAP = {\n  'pickaxe': 'Pickaxe',\n  'glider': 'Gliders',\n  'backpack': 'Back Blings',\n  'contrail': 'Contrails',\n  'wrap': 'Wraps'\n};\n\n// Collect items by type\nconst items = [];\n\nfor (const type of Object.keys(TYPE_MAP)) {\n  const filtered = cosmetics.filter(i => i.type?.value === type && (i.images?.icon || i.images?.smallIcon));\n  for (const item of filtered) {\n    items.push({\n      ...item,\n      _type: TYPE_MAP[type],\n      _rarity: normalize(item.rarity)\n    });\n  }\n}\n\n// Add Weapons (use pickaxes with different type label)\nconst weaponSources = cosmetics.filter(i => \n  (i.type?.value === 'pickaxe' || i.type?.value === 'wrap') && \n  (i.images?.icon || i.images?.smallIcon)\n).slice(0, 30);\n\nfor (const w of weaponSources) {\n  items.push({\n    ...w,\n    _type: 'Weapon',\n    _rarity: normalize(w.rarity),\n    _is_weapon: true\n  });\n}\n\n// Shuffle all\nconst shuffled = items.sort(() => Math.random() - 0.5);\n\n// Select by rarity (10 per rarity), ensuring Weapons included\nconst byRarity = {};\nfor (const r of RARITIES) byRarity[r] = [];\nfor (const i of shuffled) byRarity[i._rarity].push(i);\n\nconst selected = [];\nconst used = new Set();\n\n// First: ensure at least 15 Weapons\nconst weapons = shuffled.filter(i => i._type === 'Weapon');\nfor (const w of weapons.slice(0, 15)) {\n  if (!used.has(w.id)) {\n    selected.push(w);\n    used.add(w.id);\n  }\n}\n\n// Then: 10 per rarity\nfor (const r of RARITIES) {\n  const pool = byRarity[r].filter(i => !used.has(i.id));\n  let c = 0;\n  for (const i of pool) {\n    if (c >= config.min_per_rarity) break;\n    selected.push(i);\n    used.add(i.id);\n    c++;\n  }\n}\n\n// Fill remaining\nfor (const i of shuffled) {\n  if (selected.length >= config.count) break;\n  if (!used.has(i.id)) {\n    selected.push(i);\n    used.add(i.id);\n  }\n}\n\nreturn selected.map((item, i) => ({\n  json: {\n    id: config.id_start + i,\n    api_id: item.id,\n    name: item.name || '',\n    rarity: item._rarity,\n    type: item._type,\n    image_url: item.images?.icon || item.images?.smallIcon,\n    img_file: `${config.id_start + i}.png`,\n    _chat_id: config.chat_id,\n    _bria: config.bria_token\n  }\n}));"
      },
