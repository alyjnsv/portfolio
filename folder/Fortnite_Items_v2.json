    {
      "id": "d14c880b-1777-4fcc-9a09-7fd03783fe46",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Finalize').all();\nlet chatId = items[0]?._chat_id || 0;\n\n// Count by type\nconst typeCounts = {};\nfor (const item of items) {\n  if (!item._skip) {\n    typeCounts[item.type] = (typeCounts[item.type] || 0) + 1;\n  }\n}\n\n// CSV: id, name, image, rarity, type\nconst csv = ['id,name,image,rarity,type'];\nfor (const item of items) {\n  if (!item._skip) {\n    csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.img_file},${item.rarity},${item.type}`);\n  }\n}\n\n// Collect binaries\nconst binData = {};\nconst keys = [];\nfor (const f of finalItems) {\n  if (f.binary?.image) {\n    binData[f.json.img_file] = f.binary.image;\n    keys.push(f.json.img_file);\n  }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: keys.length, weapons: typeCounts['Weapon'] || 0 }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'items.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: keys.length, keys: keys.join(',') }, binary: binData }\n];"
      },
