    {
      "id": "d1222a5d-eacd-4205-b492-441fd9559cdb",
      "name": "Finalize",
      "parameters": {
        "jsCode": "const items = $('Has Image?').all().filter(i => !i.json._skip);\nconst meta = items[$itemIndex]?.json || {};\nconst bin = $input.item.binary || {};\nconst newBin = {};\nif (bin.image) newBin.image = { ...bin.image, fileName: meta.img_file, mimeType: 'image/png' };\nreturn { json: meta, binary: newBin };",
        "mode": "runOnceForEachItem"
      },
      "position": [
        96,
        192
      ],
