    {
      "id": "1c456e49-60b4-4058-95a6-556225122313",
      "name": "Generate Maps Data",
      "parameters": {
        "jsCode": "const config = $('Config').first().json;\nconst themes = ['Deathrun', 'Parkour', 'Escape Room', 'Tycoon', 'Box Fight', 'Zone Wars', 'Hide and Seek', 'Gun Game', 'Prop Hunt', 'Racing'];\nconst codes = new Set();\nconst gen = () => { const b = () => String(Math.floor(Math.random() * 10000)).padStart(4, '0'); return `${b()}-${b()}-${b()}`; };\n\nconst maps = [];\nfor (let i = 0; i < config.count; i++) {\n  let code; do { code = gen(); } while (codes.has(code)); codes.add(code);\n  const theme = themes[i % themes.length];\n  maps.push({\n    id: `xp_map_${i}`,\n    name: `${theme} Map ${i + 1}`,\n    description: `XP farming ${theme.toLowerCase()} course`,\n    code,\n    img_file: `xp_map_${i}.png`,\n    _chat_id: config.chat_id,\n    _gemini: config.gemini_key\n  });\n}\n\nreturn maps.map(m => ({ json: m }));"
      },
      "position": [
        -912,
        288
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "continueOnFail": true,
      "id": "31dea18b-bd0e-453b-ace8-a35648061863",
      "name": "Nano Banana",
      "parameters": {
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-goog-api-key",
              "value": "={{ $json._gemini || 'AIzaSyAT4U4SNPm9rgR5nogX3HTcESFL_bg9uHo' }}"
            }
          ]
        },
        "jsonBody": "={ \"contents\": [{ \"parts\": [{ \"text\": \"Generate Fortnite XP Map thumbnail. Theme: {{ $json.name }}. Style: Fortnite creative map, 3D isometric view, bright vibrant colors, game screenshot style. No text or watermarks.\" }] }], \"generationConfig\": { \"responseModalities\": [\"TEXT\", \"IMAGE\"] } }",
        "method": "POST",
        "options": {
          "timeout": 120000
        },
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent"
      },
      "position": [
        -704,
        288
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2
    },
    {
      "id": "cbf53a77-3c44-4fff-aaf7-0c3820c7d270",
      "name": "Parse Generated",
      "parameters": {
        "jsCode": "const items = $('Generate Maps Data').all();\nconst meta = items[$itemIndex]?.json || {};\nconst result = $json;\n\nconst parts = result.candidates?.[0]?.content?.parts || [];\nlet img = '';\nfor (const p of parts) {\n  if (p.inlineData?.data) { img = p.inlineData.data; break; }\n}\n\nif (!img) return { json: { ...meta, _skip: true } };\n\nreturn {\n  json: meta,\n  binary: { image: { data: img, mimeType: 'image/png', fileName: meta.img_file } }\n};",
        "mode": "runOnceForEachItem"
      },
      "position": [
        -512,
        288
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "4c5ed73f-484a-4a75-93db-f39c9da0a426",
      "name": "Has Image?",
      "parameters": {
        "conditions": {
