    {
      "id": "a196e7a3-de33-45dd-af45-6baeccbb9614",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Finalize').all();\nlet chatId = items[0]?._chat_id || 0;\n\nconst csv = ['id,name,code,image,description'];\nfor (const i of items) {\n  csv.push(`${i.id},\"${(i.name || '').replace(/\"/g, '')}\",${i.code},${i.img_file},\"${(i.description || '').replace(/\"/g, '')}\"`);\n}\n\nconst binData = {}, keys = [];\nfor (const f of finalItems) {\n  if (f.binary?.image) {\n    binData[f.json.img_file] = f.binary.image;\n    keys.push(f.json.img_file);\n  }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: items.length }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'xp_maps.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: items.length, keys: keys.join(',') }, binary: binData }\n];"
      },
      "position": [
        496,
        192
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
