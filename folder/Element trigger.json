        "id": "f6876514-6f0f-44e2-8669-5ab608b3224c",
        "name": "Code in JavaScript",
        "parameters": {
          "jsCode": "const out = [];\nfor (const item of $input.all()) {\n  const { json } = item;\n  const mxcUrl = json.content?.url;\n\n  if (!mxcUrl || !mxcUrl.startsWith('mxc://')) {\n    out.push({ json });\n    continue;\n  }\n\n  const match = mxcUrl.match(/^mxc:\\/\\/([^\\/]+)\\/(.+)$/);\n  if (!match) {\n    out.push({ json });\n    continue;\n  }\n\n  const [_, server, mediaId] = match;\n  // ВАЖНО: используем оригинальный сервер из MXC, а не жёстко прописанный!\n  const baseUrl = `https://${server}`;\n  const downloadUrl = `https://matrix.itcomp.org/_matrix/client/v1/media/download/${server}/${mediaId}?allow_remote=true`;\n\n  out.push({\n    json: {\n      ...json,\n      downloadUrl\n    }\n  });\n}\nreturn out;"
        },
