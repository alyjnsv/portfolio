      "name": "Format Crypto Message",
      "parameters": {
        "jsCode": "// Format cryptocurrency data into a Russian message\nconst data = $input.first().json;\n\nif (!data) {\n  return [{ json: { message: '❌ Не удалось получить данные о криптовалютах' } }];\n}\n\nlet message = '📊 *Цены криптовалют на сегодня*\\n\\n';\n\n// CoinGecko API returns nested objects for each cryptocurrency\nconst cryptos = [\n  { id: 'bitcoin', name: 'Bitcoin', symbol: 'BTC' },\n  { id: 'ethereum', name: 'Ethereum', symbol: 'ETH' },\n  { id: 'tether', name: 'Tether', symbol: 'USDT' },\n  { id: 'binancecoin', name: 'BNB', symbol: 'BNB' },\n  { id: 'solana', name: 'Solana', symbol: 'SOL' }\n];\n\nfor (const crypto of cryptos) {\n  if (data[crypto.id]) {\n    const price = data[crypto.id].usd ? parseFloat(data[crypto.id].usd).toFixed(2) : 'N/A';\n    const change24h = data[crypto.id].usd_24h_change ? parseFloat(data[crypto.id].usd_24h_change).toFixed(2) : '0';\n    \n    // Determine emoji based on price change\n    const changeEmoji = parseFloat(change24h) >= 0 ? '📈' : '📉';\n    const changeSign = parseFloat(change24h) >= 0 ? '+' : '';\n    \n    message += `${changeEmoji} *${crypto.symbol}*: $${price} (${changeSign}${change24h}%)\\n`;\n  }\n}\n\nmessage += '\\n_Обновлено: ' + new Date().toLocaleString('ru-RU') + '_';\n\nreturn [{ json: { message } }];"
      },
