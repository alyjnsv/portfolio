    {
      "id": "0dfabfb7-d091-4f72-bf08-873f88953bd9",
      "name": "Build Output1",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Finalize1').all();\nlet chatId = items[0]?._chat_id || 0;\n\n// CSV: id, name, image, rarity\nconst csv = ['id,name,image,rarity'];\nfor (const item of items) {\n  if (!item._skip) {\n    csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.img_file},${item.rarity}`);\n  }\n}\n\n// Collect binaries\nconst binData = {};\nconst keys = [];\nfor (const f of finalItems) {\n  if (f.binary?.image) {\n    binData[f.json.img_file] = f.binary.image;\n    keys.push(f.json.img_file);\n  }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: keys.length }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'skins.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: keys.length, keys: keys.join(',') }, binary: binData }\n];"
      },
