    {
      "id": "c2dbfdaf-7d1a-46bd-842e-d794f3558548",
      "name": "Fetch API1",
      "parameters": {
        "options": {
          "timeout": 120000
        },
        "url": "https://fortnite-api.com/v2/cosmetics/br"
      },
