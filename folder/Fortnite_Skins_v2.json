    {
      "id": "19f8cfcb-cce1-4083-be22-3bb359eabd26",
      "name": "Filter1",
      "parameters": {
        "jsCode": "const items = $('Parse Bria1').all();\nconst meta = items[$itemIndex]?.json || {};\nconst bin = $input.item.binary;\nif (!bin || !Object.keys(bin).length) return { json: { ...meta, _skip: true } };\nconst k = Object.keys(bin)[0];\nreturn { json: meta, binary: { image: { ...bin[k], fileName: meta.img_file, mimeType: 'image/png' } } };",
        "mode": "runOnceForEachItem"
      },
      "position": [
        -912,
