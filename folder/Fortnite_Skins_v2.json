    {
      "id": "67088896-b7c1-43be-8b87-9d66ac92c25b",
      "name": "Process Skins1",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config1').first().json;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (['common','uncommon','rare','epic','legendary'].includes(v)) return v;\n  return 'other';\n};\n\n// Filter outfits with FEATURED image (full-body)\nconst skins = cosmetics.filter(i => \n  i.type?.value === 'outfit' && \n  (i.images?.featured || i.images?.icon)\n);\n\n// Group by rarity\nconst byRarity = {};\nfor (const r of RARITIES) byRarity[r] = [];\nfor (const s of skins) byRarity[normalize(s.rarity)].push(s);\n\n// Select: min 10 per rarity, then fill to count\nconst selected = [];\nconst used = new Set();\n\n// First pass: 10 per rarity\nfor (const r of RARITIES) {\n  const pool = byRarity[r].sort(() => Math.random() - 0.5);\n  let c = 0;\n  for (const s of pool) {\n    if (c >= config.min_per_rarity) break;\n    if (used.has(s.id)) continue;\n    selected.push({ ...s, _rarity: r });\n    used.add(s.id);\n    c++;\n  }\n}\n\n// Second pass: fill remaining\nconst remaining = skins.filter(s => !used.has(s.id)).sort(() => Math.random() - 0.5);\nfor (const s of remaining) {\n  if (selected.length >= config.count) break;\n  selected.push({ ...s, _rarity: normalize(s.rarity) });\n}\n\n// Build output with 6-digit IDs\nreturn selected.map((s, i) => ({\n  json: {\n    id: config.id_start + i,\n    api_id: s.id,\n    name: s.name || '',\n    rarity: s._rarity,\n    // Prefer featured (full-body), fallback to icon\n    image_url: s.images?.featured || s.images?.icon,\n    img_file: `${config.id_start + i}.png`,\n    _chat_id: config.chat_id,\n    _bria: config.bria_token\n  }\n}));"
      },
      "position": [
        -1712,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "127fd378-4c0c-4ec5-9151-52247ef7c22b",
      "name": "Parse Bria1",
      "parameters": {
        "jsCode": "const items = $('Process Skins1').all();\nconst meta = items[$itemIndex]?.json || {};\nconst r = $json;\nconst url = r.result?.image_url || r.image_url || meta.image_url;\nreturn { json: { ...meta, processed_url: url } };",
        "mode": "runOnceForEachItem"
      },
      "position": [
        -1312,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
