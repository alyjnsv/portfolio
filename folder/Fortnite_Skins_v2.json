        "jsCode": "const meta = $json;\nconst bin = $input.item.binary || {};\nconst newBin = {};\nif (bin.image) newBin.image = { ...bin.image, fileName: meta.img_file, mimeType: 'image/png' };\nreturn { json: meta, binary: newBin };",
