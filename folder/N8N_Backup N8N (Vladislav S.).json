      "name": "isDiffOrNew",
      "parameters": {
        "jsCode": "// Рекурсивная сортировка ключей на всех уровнях\nconst orderJsonKeysDeep = (value) => {\n  if (Array.isArray(value)) {\n    return value.map(orderJsonKeysDeep);\n  }\n  if (value && typeof value === 'object') {\n    return Object.keys(value).sort().reduce((acc, k) => {\n      acc[k] = orderJsonKeysDeep(value[k]);\n      return acc;\n    }, {});\n  }\n  return value;\n};\n\n// Аккуратный парсер оригинала (content base64 или data string)\nconst parseOriginal = (json0) => {\n  if (Object.prototype.hasOwnProperty.call(json0, 'content')) {\n    const raw = json0.content; // возможно с \\n\n    const decoded = Buffer.from(String(raw).replace(/\\s+/g, ''), 'base64').toString('utf8');\n    return JSON.parse(decoded);\n  }\n  if (Object.prototype.hasOwnProperty.call(json0, 'data')) {\n    return JSON.parse(json0.data);\n  }\n  return null; // оригинала нет\n};\n\n// --- Основная логика ---\nconst items = $input.all();\nif (!items[0] || !items[1]) {\n  throw new Error('Ожидались два входных айтема: [0] с файлом/данными и [1] с текущим воркфлоу.');\n}\n\nconst json0 = items[0].json;\nconst current = items[1].json;\n\nconst original = parseOriginal(json0);\nconst orderedCurrent = orderJsonKeysDeep(current);\n\nif (original !== null) {\n  const orderedOriginal = orderJsonKeysDeep(original);\n  if (JSON.stringify(orderedOriginal) === JSON.stringify(orderedCurrent)) {\n    json0.github_status = 'same';\n  } else {\n    json0.github_status = 'different';\n    json0.n8n_data_stringy = JSON.stringify(orderedCurrent, null, 2);\n  }\n  json0.content_decoded = orderedOriginal; // объект; при необходимости можно ещё и строкой\n} else {\n  json0.github_status = 'new';\n  json0.n8n_data_stringy = JSON.stringify(orderedCurrent, null, 2);\n}\n\nreturn items;"
      },
