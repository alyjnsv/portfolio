    {
      "id": "12c0f22a-8ca2-4f52-bdb6-90fffb038433",
      "name": "Init Task Context",
      "parameters": {
        "jsCode": "// На входе здесь один task из Build Tasks From Sections\n// Пример:\n// {\n//   \"project_game\": \"Minecraft\",\n//   \"project_template\": \"Crafty\",\n//   \"section_key\": \"mods\",\n//   \"section_name\": \"Mods\",\n//   \"format\": \"file_with_preview\",\n//   \"category_index\": 1,\n//   \"target_items\": 50,\n//   \"base_output_dir\": \"/data/content\",\n//   \"text_rules\": { ... }\n// }\n\nconst task = $json;\n\nreturn [{\n  json: {\n    task,\n    // сюда потом добавим sources, items и т.д.\n    items: []\n  }\n}];"
      },
      "position": [
        1728,
        16
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "5c094e0a-5d82-426f-ac18-ae7d26308c4f",
      "name": "Fetch Sources For Section",
      "parameters": {
        "jsCode": "const ctx = $json;\nconst task = ctx.task;\n\n// В реальной жизни тут будет логика:\n// - взять список сайтов из конфига,\n// - собрать URL-ы страниц по разделу/категории\n// Пока просто подставим фейковые урлы по section_key\n\nlet sources = [];\n\nswitch (task.section_key) {\n  case 'mods':\n    sources = [\n      'https://example.com/mcpe/mods/page1',\n      'https://example.com/mcpe/mods/page2'\n    ];\n    break;\n  case 'maps':\n    sources = [\n      'https://example.com/mcpe/maps/page1'\n    ];\n    break;\n  default:\n    sources = [\n      'https://example.com/placeholder'\n    ];\n}\n\nctx.sources = sources;\n\nreturn [{ json: ctx }];"
      },
      "position": [
        1936,
        16
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "3f94e593-cf5d-47fb-a93b-95626056a4ed",
      "name": "Explode Sources",
      "parameters": {
        "jsCode": "const ctx = $json;\nconst task = ctx.task;\nconst sources = ctx.sources || [];\n\nconst items = [];\n\nsources.forEach((url, index) => {\n  items.push({\n    json: {\n      task,\n      source_url: url,\n      source_index: index + 1\n    }\n  });\n});\n\nreturn items;"
      },
      "position": [
        2144,
        16
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "acab310c-5b09-4235-8032-3e0beb1b70e3",
