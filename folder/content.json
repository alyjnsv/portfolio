      "id": "19f59d62-fa83-4ac2-b23a-8d42a38f73a7",
      "name": "Prepare Tasks",
      "parameters": {
        "functionCode": "// Берём апдейт от Telegram Trigger\nconst update = $json;\n\n// Защита от странных апдейтов без текста\nconst text = update.message?.text || '';\n\nconst parts = text.trim().split(/\\s+/);\nconst command = parts[0] || '';\nconst args = parts.slice(1);\n\n// Ожидаем формат:\n// /new_project <game> <template> <spec_url> <target_count>\nconst [game, template, specUrl, targetCountRaw] = args;\n\nconst targetCount = targetCountRaw ? Number(targetCountRaw) : null;\n\nreturn [\n  {\n    json: {\n      chat_id: update.message.chat.id,\n      message_id: update.message.message_id,\n      raw_text: text,\n      command,\n      game,\n      template,\n      spec_url: specUrl,\n      target_count: targetCount,\n      created_at: new Date().toISOString()\n    }\n  }\n];"
      },
      "position": [
        -192,
        144
      ],
      "type": "n8n-nodes-base.function",
