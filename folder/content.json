    {
      "id": "24f6db29-6461-4450-832a-f8b23ea93700",
      "name": "Parse Spec — Minecraft Crafty",
      "parameters": {
        "jsCode": "// Берём конфиг, который пришёл из Config (там уже есть game/template/chat_id/target_count/base_output_dir)\nconst cfg = $json;\n\n// Базовый объект проекта\nconst projectConfig = {\n  chat_id: cfg.chat_id,\n  game: cfg.game || 'Minecraft',\n  template: cfg.template || 'Crafty',\n  target_count: cfg.target_count || null,\n  base_output_dir: cfg.base_output_dir || '/data/content',\n\n  // Описание форматов\n  formats: {\n    file_with_preview: {\n      needs_file: true,\n      needs_image: true,\n      image: {\n        width: 640,\n        height: 480,\n        orientation: 'landscape',\n        format: 'png'\n      }\n    },\n    image_only: {\n      needs_file: false,\n      needs_image: true,\n      image: {\n        width: 640,\n        height: 480,\n        orientation: 'landscape',\n        format: 'png'\n      }\n    },\n    skin: {\n      needs_file: true,\n      needs_image: true,\n      file_extensions: ['png'],\n      image: {\n        width: 360,\n        height: 640,\n        orientation: 'portrait',\n        format: 'png'\n      }\n    }\n  },\n\n  // Секции из ТЗ Crafty Craft\n  sections: [\n    {\n      key: 'mods',\n      name: 'Mods',\n      format: 'file_with_preview',\n      file_extensions: ['mcaddon', 'mcpack'],\n      min_categories: 5,\n      min_items_per_category: 50\n    },\n    {\n      key: 'items',\n      name: 'Items',\n      format: 'image_only',\n      min_items_total: 50\n    },\n    {\n      key: 'shaders',\n      name: 'Shaders',\n      format: 'image_only',\n      min_items_total: 50\n    },\n    {\n      key: 'skins',\n      name: 'Skins',\n      format: 'skin',\n      min_categories: 5,\n      min_items_per_category: 50\n    },\n    {\n      key: 'maps',\n      name: 'Maps',\n      format: 'file_with_preview',\n      file_extensions: ['mcworld'],\n      min_categories: 5,\n      min_items_per_category: 50\n    },\n    {\n      key: 'addons',\n      name: 'Addons',\n      format: 'file_with_preview',\n      file_extensions: ['mcaddon'],\n      min_categories: 5,\n      min_items_per_category: 50\n    },\n    {\n      key: 'create_addons',\n      name: 'Create Addons',\n      format: 'file_with_preview',\n      file_extensions: ['mcaddon'],\n      min_items_total: 100\n    }\n  ],\n\n  // Общие текстовые правила\n  text_rules: {\n    language: 'en',\n    title_min: 4,\n    title_max: 30,\n    description_min: 50,\n    description_max: 3000,\n    ban_brands: true\n  }\n};\n\nreturn [{ json: projectConfig }];"
      },
      "position": [
        896,
        32
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "4b03febb-86aa-44cc-a07a-beec9d256006",
      "name": "Build Tasks From Sections",
      "parameters": {
        "jsCode": "const project = $json;\n\nconst tasks = [];\n\nconst sections = project.sections || [];\n\nfor (const section of sections) {\n  const format = section.format;\n\n  // Если у секции есть категории и элементы на категорию\n  if (section.min_categories && section.min_items_per_category) {\n    for (let categoryIndex = 1; categoryIndex <= section.min_categories; categoryIndex++) {\n      tasks.push({\n        project_game: project.game,\n        project_template: project.template,\n        section_key: section.key,\n        section_name: section.name,\n        format,\n        category_index: categoryIndex,\n        target_items: section.min_items_per_category,\n        base_output_dir: project.base_output_dir,\n        text_rules: project.text_rules || {}\n      });\n    }\n  }\n\n  // Если просто общее количество без категорий\n  if (section.min_items_total) {\n    tasks.push({\n      project_game: project.game,\n      project_template: project.template,\n      section_key: section.key,\n      section_name: section.name,\n      format,\n      category_index: null,\n      target_items: section.min_items_total,\n      base_output_dir: project.base_output_dir,\n      text_rules: project.text_rules || {}\n    });\n  }\n}\n\n// Возвращаем каждый task как отдельный item\nreturn tasks.map(t => ({ json: t }));"
      },
      "position": [
        1104,
        32
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
