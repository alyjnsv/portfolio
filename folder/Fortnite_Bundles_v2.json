    {
      "id": "1337a437-d4bc-4ec8-84ab-6adc2dfccfad",
      "name": "Build Output",
      "parameters": {
        "jsCode": "const items = $json.items || [];\nconst finalItems = $('Finalize').all();\nlet chatId = items[0]?._chat_id || 0;\n\n// CSV: id, name, image, rarity, ids (as JSON array string)\nconst csv = ['id,name,image,rarity,ids'];\nfor (const item of items) {\n  if (!item._skip) {\n    const idsStr = JSON.stringify(item.ids);\n    csv.push(`${item.id},\"${(item.name||'').replace(/\"/g,'')}\",${item.img_file},${item.rarity},\"${idsStr.replace(/\"/g, '\"\"')}\"`);\n  }\n}\n\n// Collect binaries\nconst binData = {};\nconst keys = [];\nfor (const f of finalItems) {\n  if (f.binary?.image) {\n    binData[f.json.img_file] = f.binary.image;\n    keys.push(f.json.img_file);\n  }\n}\n\nreturn [\n  { json: { type: 'csv', chat_id: chatId, count: keys.length }, binary: { file: { data: Buffer.from(csv.join('\\n')).toString('base64'), mimeType: 'text/csv', fileName: 'bundles.csv' } } },\n  { json: { type: 'zip', chat_id: chatId, count: keys.length, keys: keys.join(',') }, binary: binData }\n];"
