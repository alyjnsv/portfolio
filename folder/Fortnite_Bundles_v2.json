    {
      "id": "1889b69d-b824-4880-a3ad-1038f440aead",
      "name": "Process Bundles",
      "parameters": {
        "jsCode": "const cosmetics = $json.data || [];\nconst config = $('Config').first().json;\n\nconst RARITIES = ['common','uncommon','rare','epic','legendary','other'];\nconst normalize = r => {\n  const v = (r?.value || 'other').toLowerCase();\n  if (['common','uncommon','rare','epic','legendary'].includes(v)) return v;\n  return 'other';\n};\n\n// ID ranges from main config\nconst skinStart = config.id_ranges?.skins?.start || 100000;\nconst emoteStart = config.id_ranges?.emotes?.start || 200000;\nconst itemStart = config.id_ranges?.items?.start || 300000;\n\n// Collect components\nconst skins = cosmetics.filter(i => i.type?.value === 'outfit' && (i.images?.featured || i.images?.icon)).sort(() => Math.random() - 0.5);\nconst emotes = cosmetics.filter(i => i.type?.value === 'emote' && i.images?.icon).sort(() => Math.random() - 0.5);\nconst weapons = cosmetics.filter(i => i.type?.value === 'pickaxe' && i.images?.icon).sort(() => Math.random() - 0.5);\nconst items = cosmetics.filter(i => ['glider','backpack','contrail','wrap'].includes(i.type?.value) && i.images?.icon).sort(() => Math.random() - 0.5);\n\nconst bundles = [];\nconst usedCombos = new Set();\n\nfor (let b = 0; b < config.count; b++) {\n  if (b >= skins.length || b >= emotes.length || b >= weapons.length || b >= items.length) break;\n  \n  const skin = skins[b];\n  const emote = emotes[b];\n  const weapon = weapons[b];\n  const item = items[b];\n  \n  // Create 6-digit IDs matching the respective sections\n  const skinId = skinStart + b;\n  const emoteId = emoteStart + b;\n  const weaponId = itemStart + b;  // Weapons are in Items\n  const itemId = itemStart + 50 + b;  // Other items offset\n  \n  const comboKey = `${skinId}|${emoteId}|${weaponId}|${itemId}`;\n  if (usedCombos.has(comboKey)) continue;\n  usedCombos.add(comboKey);\n  \n  bundles.push({\n    id: config.id_start + b,\n    name: `${skin.name} Bundle`,\n    rarity: normalize(skin.rarity),\n    ids: [skinId, emoteId, weaponId, itemId],\n    image_url: skin.images?.featured || skin.images?.icon,\n    img_file: `${config.id_start + b}.png`,\n    _chat_id: config.chat_id,\n    _bria: config.bria_token\n  });\n}\n\nreturn bundles.map(b => ({ json: b }));"
      },
